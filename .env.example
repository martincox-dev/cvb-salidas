# ── Servidor ────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# ── Google OAuth2 ────────────────────────────────────────────
# Crear en: https://console.cloud.google.com → APIs → Credenciales → OAuth 2.0
# Tipo: Aplicación de escritorio (para obtener el refresh_token inicial)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Obtener el refresh_token ejecutando: npm run auth

# ── Gmail ────────────────────────────────────────────────────
# Dirección que recibe los emails de salidas
GMAIL_INBOX=cvbenicasim@gmail.com
# Etiqueta/label de Gmail para marcar emails ya procesados (se crea automáticamente)
GMAIL_PROCESSED_LABEL=cvb-salidas-procesados
# Intervalo de polling en ms (mínimo 60000)
GMAIL_POLL_INTERVAL_MS=120000

# ── Remitentes autorizados ───────────────────────────────────
# Emails que pueden registrar salidas (separados por coma)
# Si está vacío se aceptan todos (no recomendado)
ALLOWED_SENDERS=marinero@example.com

# ── Google Sheets ────────────────────────────────────────────
# ID de la hoja (extraer de la URL de Google Sheets)
# https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
SHEETS_ID=
# Nombre de la pestaña donde se escriben las salidas
SHEETS_TAB=Registro

# ── BunnyDB / libSQL (log de auditoría, opcional) ────────────
LIBSQL_URL=
LIBSQL_AUTH_TOKEN=
